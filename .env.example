# Jawafdehi MCP Server Configuration
#
# Transport mode selection (default: stdio):
#   jawafdehi-mcp        = stdio transport (for CLI / subprocess clients)
#   jawafdehi-mcp-http    = Streamable HTTP transport (for OpenWebUI etc.)
#
# HTTP transport settings (used with jawafdehi-mcp-http):
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8000
#
# In HTTP mode the server authenticates each request as an OIDC resource
# server: it verifies an "Authorization: Bearer <token>" (Zitadel access token)
# via JWKS, resolves the caller's roles from the userinfo endpoint, and forwards
# the same bearer to jawafdehi-api. Configure the four OIDC_* vars below.

# OIDC resource-server settings (required for HTTP transport / bearer auth).
# Reuse the same values as jawafdehi-api so both trust the same tokens.
OIDC_ISSUER=https://auth.jawafdehi.org
OIDC_JWKS_URL=https://auth.jawafdehi.org/oauth/v2/keys
OIDC_OP_USER_ENDPOINT=https://auth.jawafdehi.org/oidc/v1/userinfo
# Expected token audience (the Zitadel project id).
OIDC_API_AUDIENCE=your_zitadel_project_id
# Optional: the resource identifier advertised in RFC 9728 protected-resource
# metadata. Defaults to OIDC_API_AUDIENCE when unset.
# OIDC_RESOURCE=https://mcp.jawafdehi.org

# Roles that grant write-tool access (comma-separated, case-insensitive).
# Defaults to: contributor,admin,moderator
# MCP_WRITE_ROLES=contributor,admin,moderator

# Base URL for Jawafdehi API (defaults to https://api.jawafdehi.org)
JAWAFDEHI_API_BASE_URL=https://api.jawafdehi.org

# DEV/STDIO ONLY: service token fallback for upstream writes when there is no
# per-request OIDC bearer (e.g. local CLI use). Not used by the HTTP transport
# in production. Sent as an OIDC `Bearer` token — the platform is OIDC-only, the
# legacy DRF `Token` scheme is no longer honoured. Use an OIDC access token.
# JAWAFDEHI_API_TOKEN=your_oidc_access_token

# OCR Configuration for markitdown-likhit / markitdown-ocr
# Use either an OpenAI-compatible provider or Gemini.

# Required for OCR when using an OpenAI-compatible provider
OPENAI_API_KEY=your_openai_compatible_api_key

# Optional custom base URL for OpenAI-compatible providers
# OPENAI_BASE_URL=https://your-provider.example/v1/

# Required OCR model name
MARKITDOWN_OCR_MODEL=gpt-4.1-mini

# Optional custom OCR prompt
# MARKITDOWN_OCR_PROMPT=Extract Nepali text faithfully and preserve table structure.

# Gemini alternative (uses Gemini's OpenAI-compatible endpoint)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash

# Sentry error monitoring (opt-in: disabled unless SENTRY_DSN is set).
# Leave unset for local dev so no events are shipped; prod injects it via the
# jawafdehi-mcp-env secret.
# SENTRY_DSN=https://your-dsn@sentry.io/your-project
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Log level (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
# LOG_LEVEL=INFO
